#!/command/with-contenv bash
# ============================================================================
# TunnelVision — FastAPI REST API Service
# ============================================================================

API_ENABLED=${API_ENABLED:-true}
API_PORT=${API_PORT:-8081}
API_RELOAD=${API_RELOAD:-false}

if [ "$API_ENABLED" != "true" ]; then
    echo "[tunnelvision] API disabled — sleeping"
    exec sleep infinity
fi

echo "[tunnelvision] Starting API on port ${API_PORT}..."

RELOAD_FLAG=""
if [ "$API_RELOAD" = "true" ]; then
    RELOAD_FLAG="--reload"
fi

exec python3 -m uvicorn \
    api.main:app \
    --host 0.0.0.0 \
    --port "${API_PORT}" \
    --app-dir /app \
    --log-level info \
    --no-access-log \
    ${RELOAD_FLAG} \
    2>&1
